<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.robgant.cat-watcher.backup</string>

    <key>WorkingDirectory</key>
    <string>__REPO_DIR__</string>

    <key>ProgramArguments</key>
    <array>
      <string>__REPO_DIR__/.pixi/envs/default/bin/cat-watcher-backup</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>__HOUR__</integer>
      <key>Minute</key>
      <integer>__MINUTE__</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__INTERNAL_ROOT__/logs/backup.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__INTERNAL_ROOT__/logs/backup.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>CAT_WATCHER_CONFIG</key>
      <string>__REPO_DIR__/config.toml</string>
      <key>PATH</key>
      <string>__REPO_DIR__/.pixi/envs/default/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>
  </dict>
</plist>
