{
  "name": "cat-watcher-tooling",
  "version": "0.0.0",
  "private": true,
  "description": "JS-based dev tooling (stylelint) for the cat-watcher project. The project is primarily Python/pixi; this file exists only so npm-based linters have a manifest to anchor against. Do not publish.",
  "devDependencies": {
    "@stylistic/stylelint-config": "^5.0.0",
    "stylelint": "^17.11.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.9.1",
    "stylelint-plugin-logical-css": "^2.1.0",
    "stylelint-plugin-use-baseline": "^1.4.1",
    "stylelint-use-nesting": "^6.0.2"
  },
  "engines": {
    "node": ">= 24.0.0",
    "npm": ">= 11.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    }
  },
  "dependencies": {
    "stylelint-declaration-strict-value": "^1.11.1"
  }
}
