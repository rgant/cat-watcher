{
  "excludes": [
    "**/*-lock.json",
    "**/*.lock",
    "**/.basedpyright",
    "**/.cache",
    "**/.claude",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.venv",
    "**/__pycache__",
    "**/node_modules",
  ],
  "plugins": [
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.22.0.wasm",
    "https://plugins.dprint.dev/ruff-0.7.12.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
  ],

  // Common formatting
  "indentWidth": 2,
  "lineWidth": 140,
  "newLineKind": "lf",
  "useTabs": false,

  "json": {
    "commentLine.forceSpaceAfterSlashes": true,
    "preferSingleLine": false,
  },
  "markdown": {
    "emphasisKind": "underscores",
    "lineWidth": 80,
    "strongKind": "asterisks",
    "textWrap": "always",
  },
  "ruff": {
    "indentWidth": 4, // Need to override the common formatting apparently
    "lineLength": 140, // Matches ruff.toml
  },
  "toml": {
    "associations": ["!**/pyproject.toml"],
    "indentWidth": 4,
  },
}
