# Camera credentials (one shared pair for all cameras in config.toml)
CAT_WATCHER_CAMERA_USERNAME=
CAT_WATCHER_CAMERA_PASSWORD=

# Outbound email (Gmail SMTP + app password)
CAT_WATCHER_GMAIL_USER=
CAT_WATCHER_GMAIL_APP_PASSWORD=
CAT_WATCHER_ALERT_TO_ADDRESSES=  # comma-separated

# Web UI HTTP basic auth
CAT_WATCHER_WEB_USERNAME=
CAT_WATCHER_WEB_PASSWORD=
