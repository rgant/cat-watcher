{% extends "base.html.jinja" %}
{% block title %}
  Clip {{ clip.id }} · Cat Watcher
{% endblock title %}
{% block body_attrs %}
  data-no-auto-refresh
{% endblock body_attrs %}
{% block content %}
  <nav class="clip-nav" aria-label="Clip navigation">
    {% if prev_clip_id %}
      <a href="{{ url_for('clip_detail', clip_id=prev_clip_id) }}" rel="prev">← Newer</a>
    {% else %}
      <span class="clip-nav-disabled" aria-disabled="true">← Newer</span>
    {% endif %}
    <a href="{{ url_for('list_clips') }}">All clips</a>
    {% if next_clip_id %}
      <a href="{{ url_for('clip_detail', clip_id=next_clip_id) }}" rel="next">Older →</a>
    {% else %}
      <span class="clip-nav-disabled" aria-disabled="true">Older →</span>
    {% endif %}
  </nav>
  <header>
    <h1>
      {{ camera.display_name if camera else "(unknown camera)" }}·
      <time datetime="{{ clip.start_ts.isoformat() }}">{{ display_start }}</time>
    </h1>
  </header>
  <video controls preload="metadata" aria-label="Clip {{ clip.id }} video">
    <source src="{{ url_for('media_clip', clip_id=clip.id) }}" type="video/mp4">
    Your browser does not support HTML5 video.
  </video>
  {% if frames %}
    <section class="contact-sheet" aria-labelledby="contact-sheet-heading">
      <h2 id="contact-sheet-heading" class="sr-only">Frames</h2>
      <ol class="contact-sheet-list">
        {% for frame in frames %}
          <li>
            <button type="button"
                    class="contact-sheet-button"
                    data-seek-seconds="{{ frame.t_offset_seconds }}"
                    aria-label="Jump to {{ frame.display_offset }}">
              <img src="{{ url_for('media_frame', frame_id=frame.id) }}"
                   alt="Frame at {{ frame.display_offset }}"
                   loading="lazy"
                   width="320"
                   height="180">
              <span class="contact-sheet-time">{{ frame.display_offset }}</span>
              <span class="{{ 'contact-sheet-score contact-sheet-score-below' if frame.below_threshold else 'contact-sheet-score' }}">{{ frame.display_score }}</span>
            </button>
          </li>
        {% endfor %}
      </ol>
    </section>
  {% endif %}
  <section aria-labelledby="detection-heading">
    <h2 id="detection-heading">Detection</h2>
    <dl class="detail-meta">
      <dt>has_cat</dt>
      <dd>
        {{ clip.has_cat }}
      </dd>
      <dt>max_score</dt>
      <dd>
        {{ "%.3f"|format(clip.max_score) }}
      </dd>
      <dt>frames</dt>
      <dd>
        {{ clip.frames_with_cat }} / {{ clip.frames_sampled }}
      </dd>
      <dt>detector_version</dt>
      <dd>
        <code>{{ clip.detector_version }}</code>
      </dd>
      <dt>analysis_error</dt>
      <dd>
        {% if clip.analysis_error %}
          <span class="badge-error">{{ clip.analysis_error }}</span>
        {% else %}
          —
        {% endif %}
      </dd>
      <dt>manual_has_cat</dt>
      <dd>
        {% if clip.manual_has_cat is none %}
          —
        {% else %}
          {{ clip.manual_has_cat }}
        {% endif %}
      </dd>
      <dt>manual_label_at</dt>
      <dd>
        {% if clip.manual_label_at %}
          <time datetime="{{ clip.manual_label_at.isoformat() }}">{{ clip.manual_label_at.isoformat() }}</time>
        {% else %}
          —
        {% endif %}
      </dd>
      <dt>manual_label_notes</dt>
      <dd>
        {{ clip.manual_label_notes or "—" }}
      </dd>
    </dl>
  </section>
  <section aria-labelledby="label-heading">
    <h2 id="label-heading">Manual label</h2>
    <form class="label-form"
          method="post"
          action="{{ url_for('set_label', clip_id=clip.id) }}">
      <label>
        Override
        <select name="has_cat">
          <option value="true"
                  {% if clip.manual_has_cat is sameas true %}selected{% endif %}>Cat</option>
          <option value="false"
                  {% if clip.manual_has_cat is sameas false %}selected{% endif %}>Not cat</option>
        </select>
      </label>
      <label>
        Notes
        <input type="text"
               name="notes"
               value="{{ clip.manual_label_notes or '' }}"
               maxlength="500"
               placeholder="optional">
      </label>
      <button type="submit">Save manual label</button>
    </form>
    {% if clip.manual_has_cat is not none %}
      <form method="post"
            action="{{ url_for('set_label', clip_id=clip.id) }}"
            hx-delete="{{ url_for('clear_label', clip_id=clip.id) }}"
            hx-confirm="Clear the manual label for this clip?"
            hx-on::after-request="window.location.reload()">
        <button type="submit" aria-label="Clear manual label for clip {{ clip.id }}">Clear manual label</button>
      </form>
    {% endif %}
  </section>
  <script src="{{ url_for('static', path='clip_detail.js') }}" defer></script>
{% endblock content %}
